generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   // "PRODUCTION" | "SALES"
  createdAt DateTime @default(now())

  jobsCreated  Job[] @relation("CreatedBy")
  jobsAssigned Job[] @relation("AssignedTo")
  jobsAsSales  Job[] @relation("SalesOwner")
  deliveries   Delivery[] @relation("DeliveryBy")
}

model Job {
  id            String   @id @default(cuid())
  seq           Int      @unique
  docNo         String   @unique
  orderDate     DateTime
  deliveryTime  String
  customer      String
  item          String
  qty           Int
  cancelled     Boolean  @default(false)
  notes         String?

  status        String   @default("PENDING")
  // PENDING | IN_PROGRESS | PAUSED | QC | DONE | CANCELLED

  rate          Float?
  etaAuto       DateTime?
  etaManual     DateTime?
  startedAt     DateTime?
  finishedAt    DateTime?

  assignedToId  String?
  assignedTo    User?    @relation("AssignedTo", fields: [assignedToId], references: [id])

  salesOwnerId  String?
  salesOwner    User?    @relation("SalesOwner", fields: [salesOwnerId], references: [id])

  createdById   String
  createdBy     User     @relation("CreatedBy", fields: [createdById], references: [id])

  materialsDeducted Boolean @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  logs          JobLog[]
  materials     JobMaterial[]
}

model Material {
  id        String   @id @default(cuid())
  code      String?  @unique   // optional SKU / part number
  name      String
  category  String   @default("อื่นๆ")
  unit      String   @default("ชิ้น")  // ชิ้น | เส้น | เมตร | กก. | ชุด
  qty       Float    @default(0)        // current stock on hand
  minQty    Float    @default(0)        // low-stock threshold
  location  String?                     // shelf / bin
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usages        JobMaterial[]
  productUsages ProductMaterial[]
  deliveries    Delivery[]
}

// A parcel received into the warehouse by the shipping team, with a photo
// confirmation. Optionally adds to a material's stock (รับเข้าคลัง).
model Delivery {
  id          String   @id @default(cuid())
  title       String
  note        String?
  photo       String   // base64 data URL — confirmation image
  qtyReceived Float    @default(0)

  materialId  String?
  material    Material? @relation(fields: [materialId], references: [id])

  createdById String
  createdBy   User     @relation("DeliveryBy", fields: [createdById], references: [id])

  createdAt   DateTime @default(now())
}

// A cylinder model (รุ่นกระบอก) with a reusable recipe of materials per 1 unit.
// Selecting one when creating a job prefills the job's bill of materials.
model Product {
  id        String   @id @default(cuid())
  code      String?  @unique
  name      String   @unique
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  materials ProductMaterial[]
}

model ProductMaterial {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  qtyPerUnit Float    @default(0)

  @@unique([productId, materialId])
}

// Bill of materials: how much of a Material a Job consumes per produced unit.
model JobMaterial {
  id         String   @id @default(cuid())
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  qtyPerUnit Float    @default(0)

  @@unique([jobId, materialId])
}

model JobLog {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status    String
  message   String?
  createdAt DateTime @default(now())
}
