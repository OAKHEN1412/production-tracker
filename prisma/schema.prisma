generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   // "PRODUCTION" | "SALES"
  createdAt DateTime @default(now())

  jobsCreated  Job[] @relation("CreatedBy")
  jobsAssigned Job[] @relation("AssignedTo")
  jobsAsSales  Job[] @relation("SalesOwner")
  deliveries   Delivery[] @relation("DeliveryBy")
  shipments    Shipment[] @relation("ShipBy")
}

model Job {
  id            String   @id @default(cuid())
  seq           Int      @unique  // unique running number — the real job identity
  docNo         String            // customer document no. — may repeat across jobs
  orderDate     DateTime
  deliveryTime  String
  customer      String
  item          String
  qty           Int
  cancelled     Boolean  @default(false)
  notes         String?

  status        String   @default("PENDING")
  // WAITING_APPROVAL | PENDING | IN_PROGRESS | PAUSED | QC | DONE | SHIPPED | CANCELLED

  rate          Float?
  etaAuto       DateTime?
  etaManual     DateTime?
  startedAt     DateTime?
  finishedAt    DateTime?
  shippedAt     DateTime?

  assignedToId  String?
  assignedTo    User?    @relation("AssignedTo", fields: [assignedToId], references: [id])

  salesOwnerId  String?
  salesOwner    User?    @relation("SalesOwner", fields: [salesOwnerId], references: [id])

  createdById   String
  createdBy     User     @relation("CreatedBy", fields: [createdById], references: [id])

  materialsDeducted Boolean @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  logs          JobLog[]
  materials     JobMaterial[]
  assemblies    JobAssembly[]
  shipment      Shipment?
}

model Material {
  id        String   @id @default(cuid())
  code      String?  @unique   // optional SKU / part number
  name      String
  category  String   @default("อื่นๆ")
  unit      String   @default("ชิ้น")  // ชิ้น | เส้น | เมตร | กก. | ชุด
  qty       Float    @default(0)        // current stock on hand
  minQty    Float    @default(0)        // low-stock threshold
  location  String?                     // shelf / bin
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usages        JobMaterial[]
  productUsages ProductMaterial[]
  deliveries    Delivery[]
  lengths       MaterialLength[]
}

// On-hand breakdown of a length-tracked material (TUBE/ROD) by piece length.
// qty = number of เส้น at lengthMm. Sum of qty across rows == Material.qty.
// Length is stored in millimetres.
model MaterialLength {
  id         String   @id @default(cuid())
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  lengthMm   Float    // 0 = unknown length (e.g. stock restored from a cancelled job)
  qty        Float    @default(0)

  @@unique([materialId, lengthMm])
}

// A parcel received into the warehouse by the shipping team, with a photo
// confirmation. Optionally adds to a material's stock (รับเข้าคลัง).
model Delivery {
  id          String   @id @default(cuid())
  title       String
  note        String?
  photo       String   // base64 data URL — confirmation image
  qtyReceived Float    @default(0)
  lengthMm    Float    @default(0)  // length per เส้น received (mm); 0 if N/A

  materialId  String?
  material    Material? @relation(fields: [materialId], references: [id])

  createdById String
  createdBy   User     @relation("DeliveryBy", fields: [createdById], references: [id])

  createdAt   DateTime @default(now())
}

// A cylinder model (รุ่นกระบอก) with a reusable recipe of materials per 1 unit.
// Selecting one when creating a job prefills the job's bill of materials.
model Product {
  id        String   @id @default(cuid())
  code      String?  @unique
  name      String   @unique
  notes     String?
  // Cutting allowance (mm) added to every length-tracked material's cut length when
  // this model is used in a job (kerf / trim margin). 0 = none.
  cutAllowanceMm Float @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  materials  ProductMaterial[]
  assemblies ProductAssembly[]
}

// An assembly/sub-part the cylinder model is built from (ชุดประกอบ). This is the
// physical-parts list SHIPPING brings to the factory — separate from the material
// BOM (วัสดุ) and carries no stock.
model ProductAssembly {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String  // ชื่อชุด
  qty       Int     @default(1) // per produced unit

  @@index([productId])
}

// A job's copy of its model's assemblies (taken when a product is selected). What
// SHIPPING sees on the รอจัดส่ง queue (× job.qty). No stock, no material link.
model JobAssembly {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name  String
  qty   Int    @default(1) // per produced unit

  @@index([jobId])
}

model ProductMaterial {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  qtyPerUnit Float    @default(0)
  // For length-tracked materials: length (mm) cut per produced unit. 0 = count-based.
  cutLengthMm Float   @default(0)

  @@unique([productId, materialId])
}

// Bill of materials: how much of a Material a Job consumes per produced unit.
model JobMaterial {
  id         String   @id @default(cuid())
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  qtyPerUnit Float    @default(0)
  // Copied from the recipe at job time: length (mm) cut per unit. 0 = count-based.
  cutLengthMm Float   @default(0)

  @@unique([jobId, materialId])
}

// An outbound shipment: SHIPPING confirms a finished job (status DONE) has been
// sent to the customer, with a photo confirmation. One per job (jobId unique).
model Shipment {
  id          String   @id @default(cuid())
  jobId       String   @unique
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  photo       String   // base64 data URL — confirmation image
  note        String?
  shippedAt   DateTime @default(now())

  createdById String
  createdBy   User     @relation("ShipBy", fields: [createdById], references: [id])

  createdAt   DateTime @default(now())
}

model JobLog {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status    String
  message   String?
  createdAt DateTime @default(now())
}
